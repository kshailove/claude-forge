# =============================================================================
# engg-intelligence — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.
# =============================================================================

# ----- Database ---------------------------------------------------------------
# Path A (TimescaleDB Docker): postgresql+asyncpg://engg:engg@db:5432/engg_intelligence
# Path B (Managed PostgreSQL):  postgresql+asyncpg://user:pass@your-rds-host:5432/engg_intelligence
DATABASE_URL=postgresql+asyncpg://engg:engg@db:5432/engg_intelligence

# Set to "false" for managed PostgreSQL (RDS, Cloud SQL, Azure DB) — disables
# TimescaleDB hypertables and uses declarative range partitioning instead.
USE_TIMESCALEDB=true

# ----- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ----- Security ---------------------------------------------------------------
# JWT secret: MUST be at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_ME_WITH_A_64_CHAR_HEX_STRING_AT_LEAST_32_CHARS_LONG

# AES-256 encryption key for integrations.config_json. MUST be exactly 64 hex chars (32 bytes).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DB_ENCRYPTION_KEY=REPLACE_ME_WITH_EXACTLY_64_HEX_CHARS_0000000000000000000000000000000

# ----- Application ------------------------------------------------------------
# Base URL for OAuth callbacks and deep links (no trailing slash)
APP_URL=http://localhost:8000

# Environment: "production" or "development"
ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ----- Email (SendGrid) -------------------------------------------------------
# If not set, falls back to SMTP (see below)
SENDGRID_API_KEY=

# ----- Email (SMTP fallback) --------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@yourcompany.com

# ----- Slack OAuth ------------------------------------------------------------
# Required only if you are connecting a Slack workspace
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
