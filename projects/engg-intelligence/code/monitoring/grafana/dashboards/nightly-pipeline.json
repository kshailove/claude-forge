{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Nightly batch pipeline health — run duration, task status, queue depth, failures",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Nightly Run Duration",
      "description": "Duration of the most recent nightly run in minutes",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "(engg_nightly_run_completed_at - engg_nightly_run_started_at) / 60",
          "legendFormat": "Last run duration",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tasks by Status",
      "description": "Count of completed, failed, and running tasks per integration in the last nightly run",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 9, "x": 6, "y": 0},
      "options": {
        "barWidth": 0.97,
        "groupWidth": 0.7,
        "orientation": "auto",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": {"mode": "multi", "sort": "none"},
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "completed"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "failed"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "running"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]}
        ]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (integration, state) (celery_tasks_total{name=~\"app.tasks.*_ingest.*\"})",
          "legendFormat": "{{integration}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Queue Depth",
      "description": "Number of pending tasks per Celery queue over time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 9, "x": 15, "y": 0},
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "celery_queue_length{queue=\"q_github\"}",
          "legendFormat": "q_github",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "celery_queue_length{queue=\"q_jira_clickup\"}",
          "legendFormat": "q_jira_clickup",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "celery_queue_length{queue=\"q_incidents\"}",
          "legendFormat": "q_incidents",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "celery_queue_length{queue=\"q_slack\"}",
          "legendFormat": "q_slack",
          "refId": "D"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "celery_queue_length{queue=\"q_keka\"}",
          "legendFormat": "q_keka",
          "refId": "E"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "celery_queue_length{queue=\"q_digest\"}",
          "legendFormat": "q_digest",
          "refId": "F"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed Tasks (last 7 days)",
      "description": "Total count of failed Celery tasks across all queues in the past 7 days",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(celery_tasks_total{state=\"FAILURE\"}[7d])",
          "legendFormat": "Failed tasks",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["engg-intelligence", "nightly", "pipeline"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "UTC",
  "title": "Nightly Pipeline",
  "uid": "engg-nightly-pipeline",
  "version": 1
}
