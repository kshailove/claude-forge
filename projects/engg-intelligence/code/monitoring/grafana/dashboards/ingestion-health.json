      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "increase(engg_integration_records_ingested_total{integration=\"github\"}[24h])", "refId": "A"}]
    },
