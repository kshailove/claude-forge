  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "GitHub — Last Sync",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 0},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "dateTimeFromNow"}},
      "targets": [{"datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "expr": "engg_integration_last_sync_timestamp{integration=\"github\"}", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "GitHub — Records Ingested",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 4, "y": 0},
