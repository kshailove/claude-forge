{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "On-call load distribution and P1 incident rate over time",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "On-Call Hours Distribution",
      "description": "Total on-call hours per engineer in the selected time range",
      "type": "barchart",
      "gridPos": {"h": 10, "w": 14, "x": 0, "y": 0},
      "options": {
        "barWidth": 0.97,
        "groupWidth": 0.7,
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": {"mode": "single", "sort": "desc"},
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100,
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {"fillOpacity": 80}
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (engineer) (engg_oncall_hours_total)",
          "legendFormat": "{{engineer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "P1 Incident Rate",
      "description": "Number of P1 incidents per day over the past 30 days",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 10, "x": 14, "y": 0},
      "options": {
        "legend": {"calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 2, "fillOpacity": 20, "showPoints": "auto", "drawStyle": "bars"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(engg_incidents_total{severity=\"P1\"}[1d])",
          "legendFormat": "P1 incidents/day",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(engg_incidents_total{severity=\"P2\"}[1d])",
          "legendFormat": "P2 incidents/day",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10m",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["engg-intelligence", "oncall", "incidents"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "team",
        "options": [],
        "query": "label_values(engg_oncall_hours_total, team)",
        "refresh": 2,
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}
      }
    ]
  },
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "UTC",
  "title": "On-Call Load",
  "uid": "engg-oncall-load",
  "version": 1
}
