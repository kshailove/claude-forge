<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" />
      <mj-text font-size="14px" line-height="1.6" color="#1a1a2e" />
      <mj-section padding="0" />
    </mj-attributes>
    <mj-style>
      .metric-value { font-size: 24px; font-weight: 700; color: #0f172a; }
      .metric-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
      .section-title { font-size: 16px; font-weight: 700; color: #0f172a; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin-bottom: 12px; }
      .card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; }
    </mj-style>
  </mj-head>
  <mj-body background-color="#f8fafc">

    <!-- Header -->
    <mj-section background-color="#0f172a" padding="20px 24px">
      <mj-column>
        <mj-text color="#ffffff" font-size="20px" font-weight="700" padding="0">
          Engg Intelligence
        </mj-text>
        <mj-text color="#94a3b8" font-size="13px" padding="4px 0 0 0">
          Weekly Digest — {{ week_label }}
        </mj-text>
      </mj-column>
      <mj-column>
        <mj-text color="#94a3b8" font-size="12px" align="right" padding="0">
          {{ current_date }}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Greeting -->
    <mj-section background-color="#ffffff" padding="20px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="18px" font-weight="700" color="#0f172a" padding="0">
          Hi {{ username }}, here's your week in review
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Section: Your week in code -->
    <mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text css-class="section-title" font-size="16px" font-weight="700" color="#0f172a" padding="0 0 8px 0">
          Your week in code
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#ffffff" padding="0 24px 16px 24px">
      <mj-column border="1px solid #e2e8f0" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" color="#0f172a" padding="0" align="center">
          {{ prs_authored }}
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          PRs Authored
        </mj-text>
      </mj-column>
      <mj-column border="1px solid #e2e8f0" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" color="#0f172a" padding="0" align="center">
          {{ prs_merged }}
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          PRs Merged
        </mj-text>
      </mj-column>
      <mj-column border="1px solid #e2e8f0" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" color="#0f172a" padding="0" align="center">
          {{ avg_cycle_time_hours }}h
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          Avg Cycle Time
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Section: Review Activity -->
    <mj-section background-color="#f8fafc" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#0f172a" padding="0 0 8px 0">
          Review activity
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#f8fafc" padding="0 24px 16px 24px">
      <mj-column border="1px solid #e2e8f0" background-color="#ffffff" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" color="#0f172a" padding="0" align="center">
          {{ prs_reviewed }}
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          PRs Reviewed
        </mj-text>
      </mj-column>
      <mj-column border="1px solid #e2e8f0" background-color="#ffffff" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" color="#0f172a" padding="0" align="center">
          {{ avg_first_review_latency_hours }}h
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          Avg First-Review Latency
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Section: Task Delivery -->
    <mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#0f172a" padding="0 0 8px 0">
          Task delivery
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#ffffff" padding="0 24px 16px 24px">
      <mj-column border="1px solid #e2e8f0" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" color="#0f172a" padding="0" align="center">
          {{ tickets_closed }}
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          Tickets Closed
        </mj-text>
      </mj-column>
      <mj-column border="1px solid #e2e8f0" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" {% if carry_overs > 0 %}color="#dc2626"{% else %}color="#16a34a"{% endif %} padding="0" align="center">
          {{ carry_overs }}
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          Carry-Overs
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Section: Incident Load -->
    <mj-section background-color="#f8fafc" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#0f172a" padding="0 0 8px 0">
          Incident load
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#f8fafc" padding="0 24px 16px 24px">
      <mj-column border="1px solid #e2e8f0" background-color="#ffffff" border-radius="8px" padding="16px">
        <mj-text css-class="metric-value" font-size="28px" font-weight="700" {% if pages_this_week > 0 %}color="#d97706"{% else %}color="#16a34a"{% endif %} padding="0" align="center">
          {{ pages_this_week }}
        </mj-text>
        <mj-text css-class="metric-label" font-size="11px" color="#64748b" padding="2px 0 0 0" align="center">
          Pages Received This Week
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Footer -->
    <mj-section background-color="#f1f5f9" padding="16px 24px">
      <mj-column>
        <mj-text color="#94a3b8" font-size="11px" align="center" padding="0">
          You are receiving this digest because you are an active user of Engg Intelligence.
          This is an automated weekly summary. Do not reply to this email.
        </mj-text>
        <mj-text color="#94a3b8" font-size="11px" align="center" padding="4px 0 0 0">
          Generated at {{ generated_at }} UTC
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
