<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" />
      <mj-text font-size="14px" line-height="1.6" color="#1a1a2e" />
      <mj-section padding="0" />
    </mj-attributes>
    <mj-style>
      .rag-green { background-color: #16a34a; color: #ffffff; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; }
      .rag-amber { background-color: #d97706; color: #ffffff; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; }
      .rag-red   { background-color: #dc2626; color: #ffffff; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; }
      .metric-value { font-size: 24px; font-weight: 700; color: #0f172a; }
      .metric-label { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
      .section-title { font-size: 16px; font-weight: 700; color: #0f172a; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin-bottom: 12px; }
      .risk-item { background: #fef2f2; border-left: 3px solid #dc2626; padding: 8px 12px; margin: 4px 0; border-radius: 0 4px 4px 0; }
      table.dora-table { width: 100%; border-collapse: collapse; font-size: 13px; }
      table.dora-table th { background: #f1f5f9; padding: 8px; text-align: left; font-weight: 600; color: #475569; }
      table.dora-table td { padding: 8px; border-bottom: 1px solid #e2e8f0; }
      .band-elite { color: #16a34a; font-weight: 600; }
      .band-high  { color: #0284c7; font-weight: 600; }
      .band-medium{ color: #d97706; font-weight: 600; }
      .band-low   { color: #dc2626; font-weight: 600; }
    </mj-style>
  </mj-head>
  <mj-body background-color="#f8fafc">

    <!-- Header -->
    <mj-section background-color="#0f172a" padding="20px 24px">
      <mj-column>
        <mj-text color="#ffffff" font-size="20px" font-weight="700" padding="0">
          Engg Intelligence
        </mj-text>
        <mj-text color="#94a3b8" font-size="13px" padding="4px 0 0 0">
          Weekly Digest — {{ week_label }}
        </mj-text>
      </mj-column>
      <mj-column>
        <mj-text color="#94a3b8" font-size="12px" align="right" padding="0">
          {{ current_date }}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Main content injected by child templates -->
    {% block content %}{% endblock %}

    <!-- Footer -->
    <mj-section background-color="#f1f5f9" padding="16px 24px">
      <mj-column>
        <mj-text color="#94a3b8" font-size="11px" align="center" padding="0">
          You are receiving this digest because you are an active user of Engg Intelligence.
          This is an automated weekly summary. Do not reply to this email.
        </mj-text>
        <mj-text color="#94a3b8" font-size="11px" align="center" padding="4px 0 0 0">
          Generated at {{ generated_at }} UTC
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
