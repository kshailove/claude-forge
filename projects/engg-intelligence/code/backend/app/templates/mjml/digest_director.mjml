<mjml>
  <mj-head>
    <mj-attributes>
      <mj-all font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" />
      <mj-text font-size="14px" line-height="1.6" color="#1a1a2e" />
      <mj-section padding="0" />
    </mj-attributes>
    <mj-style>
      .rag-green { background-color: #16a34a; color: #ffffff; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; display: inline-block; }
      .rag-amber { background-color: #d97706; color: #ffffff; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; display: inline-block; }
      .rag-red   { background-color: #dc2626; color: #ffffff; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; display: inline-block; }
      .band-elite { color: #16a34a; font-weight: 600; }
      .band-high  { color: #0284c7; font-weight: 600; }
      .band-medium{ color: #d97706; font-weight: 600; }
      .band-low   { color: #dc2626; font-weight: 600; }
    </mj-style>
  </mj-head>
  <mj-body background-color="#f8fafc">

    <!-- Header -->
    <mj-section background-color="#0f172a" padding="20px 24px">
      <mj-column>
        <mj-text color="#ffffff" font-size="20px" font-weight="700" padding="0">
          Engg Intelligence
        </mj-text>
        <mj-text color="#94a3b8" font-size="13px" padding="4px 0 0 0">
          Weekly Digest — {{ week_label }}
        </mj-text>
      </mj-column>
      <mj-column>
        <mj-text color="#94a3b8" font-size="12px" align="right" padding="0">
          {{ current_date }}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Greeting -->
    <mj-section background-color="#ffffff" padding="20px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="18px" font-weight="700" color="#0f172a" padding="0">
          Hi {{ username }}, here's your cross-team engineering health report
        </mj-text>
        <mj-text font-size="13px" color="#64748b" padding="4px 0 0 0">
          {{ total_teams }} team{{ "s" if total_teams != 1 else "" }} tracked this week
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Section: Cross-Team Health Overview -->
    <mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#0f172a" padding="0 0 8px 0">
          Cross-team health overview
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#ffffff" padding="0 24px 16px 24px">
      <mj-column>
        <mj-table>
          <tr style="background: #f1f5f9;">
            <th style="padding: 8px 12px; text-align: left; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Team</th>
            <th style="padding: 8px 12px; text-align: center; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Status</th>
            <th style="padding: 8px 12px; text-align: right; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Score</th>
            <th style="padding: 8px 12px; text-align: right; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">PR</th>
            <th style="padding: 8px 12px; text-align: right; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Sprint</th>
            <th style="padding: 8px 12px; text-align: right; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Incident</th>
          </tr>
          {% for team in teams %}
          <tr>
            <td style="padding: 8px 12px; font-size: 13px; font-weight: 500; border-bottom: 1px solid #e2e8f0;">{{ team.name }}</td>
            <td style="padding: 8px 12px; font-size: 13px; text-align: center; border-bottom: 1px solid #e2e8f0;">
              <span class="rag-{{ team.rag }}">{{ team.rag | upper }}</span>
            </td>
            <td style="padding: 8px 12px; font-size: 13px; font-weight: 700; text-align: right; border-bottom: 1px solid #e2e8f0;">{{ team.composite_score | round(0) | int }}</td>
            <td style="padding: 8px 12px; font-size: 13px; text-align: right; border-bottom: 1px solid #e2e8f0;">{{ team.pr_health_score | default("—") }}</td>
            <td style="padding: 8px 12px; font-size: 13px; text-align: right; border-bottom: 1px solid #e2e8f0;">{{ team.sprint_health_score | default("—") }}</td>
            <td style="padding: 8px 12px; font-size: 13px; text-align: right; border-bottom: 1px solid #e2e8f0;">{{ team.incident_load_score | default("—") }}</td>
          </tr>
          {% endfor %}
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- Section: Risk Flags -->
    {% if risk_teams %}
    <mj-section background-color="#f8fafc" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#dc2626" padding="0 0 8px 0">
          Risk flags
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#f8fafc" padding="0 24px 16px 24px">
      <mj-column>
        {% for rt in risk_teams %}
        <mj-text font-size="13px" color="#7f1d1d" padding="4px 0"
          container-background-color="#fef2f2"
          border-left="3px solid #dc2626">
          <strong>{{ rt.name }}</strong> ({{ rt.rag | upper }}, {{ rt.composite_score | round(0) | int }}/100)
          {% for issue in rt.issues %}
          — {{ issue }}
          {% endfor %}
        </mj-text>
        {% endfor %}
      </mj-column>
    </mj-section>
    {% endif %}

    <!-- Section: DORA Comparison -->
    <mj-section background-color="#ffffff" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#0f172a" padding="0 0 8px 0">
          DORA comparison
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#ffffff" padding="0 24px 16px 24px">
      <mj-column>
        <mj-table>
          <tr style="background: #f1f5f9;">
            <th style="padding: 8px 12px; text-align: left; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Team</th>
            <th style="padding: 8px 12px; text-align: center; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Deploy Freq</th>
            <th style="padding: 8px 12px; text-align: center; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">Lead Time</th>
            <th style="padding: 8px 12px; text-align: center; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">CFR</th>
            <th style="padding: 8px 12px; text-align: center; font-size: 12px; color: #475569; border-bottom: 2px solid #e2e8f0;">MTTR</th>
          </tr>
          {% for team in teams_dora %}
          <tr>
            <td style="padding: 8px 12px; font-size: 13px; font-weight: 500; border-bottom: 1px solid #e2e8f0;">{{ team.name }}</td>
            <td style="padding: 8px 12px; font-size: 12px; text-align: center; border-bottom: 1px solid #e2e8f0;" class="band-{{ team.deploy_freq_band | lower }}">{{ team.deploy_freq_band }}</td>
            <td style="padding: 8px 12px; font-size: 12px; text-align: center; border-bottom: 1px solid #e2e8f0;" class="band-{{ team.lead_time_band | lower }}">{{ team.lead_time_band }}</td>
            <td style="padding: 8px 12px; font-size: 12px; text-align: center; border-bottom: 1px solid #e2e8f0;" class="band-{{ team.cfr_band | lower }}">{{ team.cfr_band }}</td>
            <td style="padding: 8px 12px; font-size: 12px; text-align: center; border-bottom: 1px solid #e2e8f0;" class="band-{{ team.mttr_band | lower }}">{{ team.mttr_band }}</td>
          </tr>
          {% endfor %}
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- Section: Top Performers -->
    {% if top_performers %}
    <mj-section background-color="#f8fafc" padding="16px 24px 8px 24px">
      <mj-column>
        <mj-text font-size="16px" font-weight="700" color="#16a34a" padding="0 0 8px 0">
          Top performers
        </mj-text>
        <mj-text font-size="13px" color="#64748b" padding="0">
          Teams that improved most this week
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#f8fafc" padding="0 24px 16px 24px">
      <mj-column>
        {% for tp in top_performers %}
        <mj-text font-size="13px" color="#14532d" padding="4px 0"
          container-background-color="#f0fdf4"
          border-left="3px solid #16a34a">
          <strong>{{ tp.name }}</strong> —
          Score: {{ tp.composite_score | round(0) | int }}/100
          {% if tp.score_delta %}(+{{ tp.score_delta | round(1) }} this week){% endif %}
        </mj-text>
        {% endfor %}
      </mj-column>
    </mj-section>
    {% endif %}

    <!-- Footer -->
    <mj-section background-color="#f1f5f9" padding="16px 24px">
      <mj-column>
        <mj-text color="#94a3b8" font-size="11px" align="center" padding="0">
          You are receiving this digest because you are an active user of Engg Intelligence.
          This is an automated weekly summary. Do not reply to this email.
        </mj-text>
        <mj-text color="#94a3b8" font-size="11px" align="center" padding="4px 0 0 0">
          Generated at {{ generated_at }} UTC
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
